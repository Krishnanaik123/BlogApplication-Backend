const db = require('../Config/db');

const updatePost = async (data) => {
    try {
        const { PostId, title, content, category_id, AuthorId, ImageUrl } = data;

        if (!PostId || !title || !content || !category_id || !AuthorId) {
            return {
                success: false,
                message: "All fields are required"
            };
        }

        // If ImageUrl is provided (new image uploaded), update it. Otherwise, keep existing image
        let query;
        let values;

        if (ImageUrl) {
            query = `
                UPDATE posts
                SET Title = ?, Content = ?, CategoryId = ?, AuthorId = ?, ImageUrl = ?
                WHERE PostId = ?
            `;
            values = [title, content, category_id, AuthorId, ImageUrl, PostId];
        } else {
            query = `
                UPDATE posts
                SET Title = ?, Content = ?, CategoryId = ?, AuthorId = ?
                WHERE PostId = ?
            `;
            values = [title, content, category_id, AuthorId, PostId];
        }

        const [result] = await db.execute(query, values);

        if (result.affectedRows === 0) {
            return {
                success: false,
                message: "Post not found"
            };
        }

        return {
            success: true,
            message: "Post updated successfully"
        };
    } catch (error) {
        throw error;
    }
};

module.exports = { updatePost };